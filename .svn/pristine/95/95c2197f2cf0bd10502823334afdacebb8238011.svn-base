package Carcassone.model;

/**
 * Jatekosok altal lerakhato meeple pozicioval tarolva
 */

public class Meeple {

    private final Player owner;
    private final TerrainFeature feature;

    /**
     * Konstruktor
     * @param owner   a meeple tulajdonosa
     * @param feature terulet tipusa
     */
    public Meeple(Player owner, TerrainFeature feature) {
        this.owner = owner;
        this.feature = feature;
    }

    /** Get fuggvenyek */
    public Player getOwner() { return owner; }

    public TerrainFeature getFeature() { return feature; }
}
