package Carcassone.gui;

import Carcassone.network.client.ServerConnection;
import Carcassone.network.shared.Message;
import Carcassone.network.shared.MessageType;
import Carcassone.network.client.MessageListener;
import javafx.application.Platform;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.control.TextField;
import javafx.scene.layout.VBox;

/** A bejelentkezo kepernyo */
public class LoginScreen {

    private final VBox root;

    /** A bejelentkezo kepernyo elemei */
    public LoginScreen() {
        Label title = new Label("Carcassonne");
        title.setStyle("-fx-font-size: 32px; -fx-font-weight: bold;");

        Label nameLabel = new Label("Felhasznalonev:");
        TextField nameField = new TextField();
        nameField.setPromptText("Add meg a neved...");
        nameField.setMaxWidth(300);

        Label errorLabel = new Label("");
        errorLabel.setStyle("-fx-text-fill: red;");

        Button connectButton = new Button("Csatlakozas");
        connectButton.setDefaultButton(true);
        connectButton.setOnAction(e -> {
            String username = nameField.getText().trim();

            if (username.isEmpty()) {
                errorLabel.setText("A felhasznalonev nem lehet ures!");
                return;
            }

            connectButton.setDisable(true);
            errorLabel.setStyle("-fx-text-fill: #888;");
            errorLabel.setText("Csatlakozas...");

            new Thread(() -> {
                try {
                    ServerConnection conn = new ServerConnection();
                    conn.connect("localhost", 8080);

                    Message loginMsg = new Message(MessageType.LOGIN);
                    loginMsg.put("username", username);
                    conn.send(loginMsg);

                    MessageListener[] listenerHolder = new MessageListener[1];
                    listenerHolder[0] = msg -> {
                        Platform.runLater(() -> {
                            if (msg.getMessageType() == MessageType.LOGIN_OK) {
                                conn.removeListener(listenerHolder[0]);
                                SceneManager.setConnection(conn);
                                SceneManager.setUsername(username);
                                SceneManager.showLobby(username);
                            } else if (msg.getMessageType() == MessageType.ERROR) {
                                conn.removeListener(listenerHolder[0]);
                                errorLabel.setStyle("-fx-text-fill: red;");
                                errorLabel.setText(msg.getString("msg"));
                                connectButton.setDisable(false);
                                conn.disconnect();
                            }
                        });
                    };
                    conn.addListener(listenerHolder[0]);

                } catch (Exception ex) {
                    Platform.runLater(() -> {
                        errorLabel.setStyle("-fx-text-fill: red;");
                        errorLabel.setText("Hiba: " + ex.getMessage() +
                                " (" + ex.getClass().getSimpleName() + ")");
                        connectButton.setDisable(false);
                    });
                }
            }).start();
        });

        root = new VBox(15);
        root.setAlignment(Pos.CENTER);
        root.setPadding(new Insets(40));
        root.getChildren().addAll(
                title,
                nameLabel, nameField,
                errorLabel,
                connectButton
        );
    }

    /** Get fuggveny */
    public VBox getRoot() {
        return root;
    }
}